{
  "name": "@mainset/ui-core",
  "version": "0.1.0",
  "description": "Basic SCSS, TypeScript and JS configurations for mainset UI",
  "keywords": [],
  "author": "Yevhen Uzhva <yevhen.uzhva@gmail.com>",
  "license": "CC-BY-NC-4.0",
  "type": "module",
  "sideEffects": [
    "dist/**/*.css"
  ],
  "files": [
    "dist",
    "src/styles/_mixins.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.mts",
      "import": "./dist/esm/index.mjs"
    },
    "./styles/normalize.css": "./dist/esm/styles/normalize.css",
    "./scss/mixins": "./src/styles/_mixins.scss"
  },
  "devDependencies": {
    "@mainset/builder-rslib": "^0.3.1",
    "@mainset/cli": "^0.5.0",
    "@mainset/dev-stack-fe": "^0.2.1",
    "@mainset/toolkit-js": "^0.2.0"
  },
  "scripts": {
    "dev": "ms-cli node-sourcer --exec watch -t web --bundless",
    "build": "ms-cli node-sourcer --exec build -t web --bundless"
  },
  "packageManager": "pnpm@10.33.0"
}

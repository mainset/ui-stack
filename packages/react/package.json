{
  "name": "@mainset/react",
  "version": "0.1.1",
  "description": "Set of UI React elements, components, hooks, etc for creating user interfaces, based on the mainset design system.",
  "repository": "https://github.com/mainset/ui-stack/tree/main/packages/react",
  "author": "Yevhen Uzhva <yevhen.uzhva@gmail.com>",
  "license": "CC-BY-NC-4.0",
  "type": "module",
  "sideEffects": [
    "dist/**/*.css"
  ],
  "files": [
    "dist",
    "src/elements/styles/_mixins.scss"
  ],
  "exports": {
    "./elements": {
      "types": "./dist/types/src/elements/index.d.mts",
      "import": "./dist/esm/elements/index.mjs"
    },
    "./components": {
      "types": "./dist/types/src/components/index.d.mts",
      "import": "./dist/esm/components/index.mjs"
    },
    "./containers": {
      "types": "./dist/types/src/containers/index.d.mts",
      "import": "./dist/esm/containers/index.mjs"
    },
    "./hooks": {
      "types": "./dist/types/src/hooks/index.d.mts",
      "import": "./dist/esm/hooks/index.mjs"
    },
    "./styles/main.css": "./dist/esm/elements/styles/main.css",
    "./scss/mixins": "./src/elements/styles/_mixins.scss"
  },
  "scripts": {
    "dev": "ms-cli node-sourcer --exec watch --bundless",
    "build": "ms-cli node-sourcer --exec build --bundless"
  },
  "dependencies": {
    "@mainset/ui-core": "workspace:^"
  },
  "devDependencies": {
    "@mainset/builder-rslib": "^0.3.1",
    "@mainset/cli": "^0.5.0",
    "@mainset/dev-stack-fe": "^0.2.1",
    "@mainset/toolkit-js": "^0.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "react": ">=19.2.0 <20.0.0",
    "react-dom": ">=19.2.0 <20.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}

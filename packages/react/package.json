{
  "name": "@mainset/react",
  "version": "0.0.1",
  "description": "Set of UI React elements, components, hooks, etc for creating user interfaces, based on the mainset design system.",
  "repository": "https://github.com/mainset/ui-stack/tree/main/packages/react",
  "author": "Yevhen Uzhva <yevhen.uzhva@gmail.com>",
  "license": "CC-BY-NC-4.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src/ui-elements/styles/_mixins.scss",
    "src/ui-elements/styles/_utilities.scss",
    "src/ui-elements/styles/utilities/_spacing.scss",
    "src/ui-elements/hocs/Typography/_builder.scss"
  ],
  "exports": {
    "./hooks": {
      "types": "./dist/types/src/hooks/index.d.mts",

    },
    "./styles/main.css": "./dist/esm/ui-elements/styles/main.css",
    "./scss/mixins": "./src/ui-elements/styles/_mixins.scss",
    "./scss/utilities": "./src/ui-elements/styles/_utilities.scss",
    "./scss/typography-builder": "./src/ui-elements/hocs/Typography/_builder.scss"
  },
  "scripts": {
    "dev": "ms-cli node-sourcer --exec watch --bundless",
    "build": "ms-cli node-sourcer --exec build --bundless"
  },
  "devDependencies": {
    "@mainset/builder-rslib": "^0.3.1-rc.2",
    "@mainset/cli": "^0.5.0",
    "@mainset/dev-stack-fe": "^0.2.1",
    "@mainset/toolkit-js": "^0.2.0-rc.1",
    "@mainset/ui-core": "workspace:^",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "lodash": ">=4.17.15 <5.0.0",
    "react": ">=19.2.0 <20.0.0",
    "react-dom": ">=19.2.0 <20.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
